# Application Configuration
# Copy this file to .env and update values as needed

# Directory path for scans
SCANS_DIR=./scans

# Server host
HOST=127.0.0.1

# Server port
PORT=8000

# Debug mode (enables reload and verbose logging)
DEBUG=false

# mDNS/Bonjour configuration
# Enable mDNS service advertisement for local network discovery
MDNS_ENABLED=true

# Service name for mDNS (results in <name>.local, e.g., "macbook.local")
MDNS_SERVICE_NAME=macbook
